@implements IDisposable
@rendermode InteractiveServer

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">TeacherAssessment</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        @if (SessionState.IsLoggedIn) {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="sessions">
                    <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Sessions
                </NavLink>
            </div>

            <div class="nav-item px-3 mt-3">
                <small class="text-light px-3">
                    Signed in as <strong>@SessionState.CurrentUser!.Username</strong>
                </small>
            </div>

            <div class="nav-item px-3">
                <button class="nav-link btn btn-link text-start w-100" @onclick="LogoutAsync">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Log out
                </button>
            </div>
        } else {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="login">
                    <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Log in
                </NavLink>
            </div>
        }
    </nav>
</div>